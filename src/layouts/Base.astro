---
import '../styles/global.css';
import site from '../data/site.json';
const {
  title = `${site.namaLengkap} | ${site.tagline}`,
  description = 'Melon dan sayuran hidroponik segar, higienis, dan bebas pestisida dari Kediri. Pesan mudah via WhatsApp.',
} = Astro.props;
const ogImage = new URL(site.heroGambar, Astro.site).href;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a2e1a" />
    <link rel="icon" type="image/png" href="/images/logo-sanjaya.png" />
    <link rel="apple-touch-icon" href="/images/logo-sanjaya.png" />
    <link rel="preload" as="image" href={site.heroGambar} />

    <!-- Open Graph (tampilan rapi saat dibagikan di WhatsApp / Instagram / Facebook) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.namaLengkap} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="id_ID" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500;1,9..144,600&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <!-- Netlify Identity: menyelesaikan proses undangan login pemilik ke /admin -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on('init', (user) => {
          if (!user) {
            window.netlifyIdentity.on('login', () => {
              document.location.href = '/admin/';
            });
          }
        });
      }
    </script>
  </body>
</html>
